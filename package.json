{
  "name": "robo-adviser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "data:holdings": "node scripts/fetch-holdings-history.mjs",
    "data:shares": "node scripts/fetch-shares-history.mjs",
    "data:build": "node scripts/build-dataset.mjs",
    "data:validate": "node scripts/validate-data.mjs",
    "data:refresh": "npm run data:holdings && npm run data:shares && npm run data:build && npm run data:validate"
  },
  "dependencies": {
    "next": "^15.5.14",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "2.15.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "22.13.14",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "typescript": "5.8.2"
  }
}
